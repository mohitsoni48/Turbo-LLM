# llama-turbo repo .gitignore
# Tracks: docs/ (product strategy), CLAUDE.md, RESOURCES.md, small control
# scripts, and (going forward) the TurboLLM product code under turbollm/.
# Does NOT track the heavy local-inference stack, secrets, or runtime state.
# NOTE: .gitignore does not support inline comments — keep patterns on their own lines.

# Heavy local-inference stack (multi-GB; not product source)
/atomic/
/cuda/
/openwebui/
/_archive/

# Secrets & runtime state
/.webui_secret_key
/.run/
.omc/

# Model weights & large binaries
*.gguf
*.safetensors
*.bin
*.exe
*.dll
*.lib
*.pdb
*.zip
*.7z
*.log

# TurboLLM daemon (Node/TS) build outputs
/turbollm/dist/
/turbollm/src/webdist/
/turbollm/bin/

# Local dev/preview config (machine-specific engine/model paths) + runtime
/turbollm/dev-config.json
/turbollm/.preview-config.json
/turbollm/daemon.pid

# Node / React frontend
node_modules/
.vite/
*.local

# Editor / OS cruft
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
